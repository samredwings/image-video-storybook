    let consentStyle = baseRequirement;
    
    if (trust > 80 && ['lovers', 'dominantSubmissive', 'ownerOwned'].includes(archetype)) {
      consentStyle = 'pre-negotiated-with-safewords';
    }

    // Build check-in points based on roughness
    const checkinPoints = [];
    if (this.TONES[toneId]?.roughness > 0.5) {
      checkinPoints.push('before-start');
      checkinPoints.push('after-first-intense-moment');
      checkinPoints.push('mid-scene-verbal-check');
      checkinPoints.push('after-climax');
    }

    return {
      style: consentStyle,
      checkinPoints,
      safewordRequired: this.TONES[toneId]?.roughness > 0.6,
      canWithdrawAnytime: true,
      nonVerbalCues: trust > 60, // Read body language if trust is established
    };
  }

  /**
   * Find the closest allowed tone to a requested one
   */
  findClosestTone(requestedId, allowedTones) {
    // Tone similarity groups
    const groups = {
      tender: ['tender', 'reverent', 'passionate'],
      passionate: ['passionate', 'tender', 'desperate'],
      playful: ['playful', 'teasing', 'sarcastic'],
      desperate: ['desperate', 'rough', 'guilty'],
      rough: ['rough', 'aggressive', 'commanding', 'desperate'],
      reverent: ['reverent', 'tender', 'passionate'],
      commanding: ['commanding', 'rough', 'dominant'],
      guilty: ['guilty', 'desperate', 'tender'],
      aggressive: ['aggressive', 'rough', 'commanding'],
      sarcastic: ['sarcastic', 'playful', 'rough'],
    };

    // Find the requested group
    const group = groups[requestedId] || [requestedId];
    
    // Find first allowed match
    for (const tone of group) {
      if (allowedTones.includes(tone)) return tone;
    }

    // Fallback to first allowed
    return allowedTones[0] || 'tender';
  }

