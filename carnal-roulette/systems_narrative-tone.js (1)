  /**
   * MAIN API: Resolve the active tone for a scene
   * 
   * Called when a scene starts or transitions.
   * Takes character relationship data + narrative context
   * and returns the resolved tone profile.
   * 
   * @param {Object} context - From parent app
   * @param {Object} context.character - The receiving character
   * @param {Object} context.relationship - Relationship state
   * @param {string} context.narrativeTone - Suggested tone from story
   * @param {string} context.narrativePosition - Scene position in story
   * @param {number} context.intensity - 1-10 scene intensity
   * @returns {Object} Resolved tone configuration
   */
  resolveSceneTone(context) {
    const {
      character,
      relationship,
      narrativeTone,
      narrativePosition,
      intensity,
    } = context;

    // 1. Get relationship archetype
    const archetype = this.RELATIONSHIP_ARCHETYPES[relationship?.archetype] 
      || this.RELATIONSHIP_ARCHETYPES.strangers;

    // 2. Determine allowed tones
    const allowedTones = archetype.allowedTones;

    // 3. Select tone: narrative suggested, or default from archetype
    let toneId = narrativeTone || archetype.defaultTone;
    
    // Validate against allowed tones
    if (!allowedTones.includes(toneId)) {
      // Find closest allowed tone
      toneId = this.findClosestTone(toneId, allowedTones);
    }

    // 4. Get the tone profile
    const toneProfile = { ...this.TONES[toneId] };
    if (!toneProfile) {
      console.warn(`[NarrativeTone] Unknown tone: ${toneId}, falling back`);
      return this.resolveSceneTone({ ...context, narrativeTone: archetype.defaultTone });
    }

    // 5. Modulate by intensity (1-10 scales tone parameters)
    const intensityFactor = (intensity || 5) / 5; // 0.2 to 2.0, centered at 1.0
    
    toneProfile.speed = THREE.MathUtils.clamp(toneProfile.speed * intensityFactor, 0.1, 1.0);
    toneProfile.roughness = THREE.MathUtils.clamp(toneProfile.roughness * intensityFactor, 0, 1.0);
    toneProfile.dialogueIntensity = THREE.MathUtils.clamp(toneProfile.dialogueIntensity * intensityFactor, 0, 1.0);

    // 6. Modulate by relationship trust
    const trust = relationship?.trust ?? archetype.baseTrust;
    const trustModifier = trust / 100; // 0-1
    
    // Higher trust allows more intense tones without breaking consent
    toneProfile.consentStability = trustModifier;

    // 7. Modulate by narrative position
    if (narrativePosition === 'climax') {
      toneProfile.speed = Math.min(1.0, toneProfile.speed * 1.3);
      toneProfile.roughness = Math.min(1.0, toneProfile.roughness * 1.2);
    } else if (narrativePosition === 'resolution' || narrativePosition === 'aftercare') {
      toneProfile.speed *= 0.5;
      toneProfile.roughness *= 0.3;
      toneProfile.touchGentleness = Math.max(toneProfile.touchGentleness, 0.7);
    }

    // 8. Generate emotional context for the scene
    const emotions = this.generateEmotionalContext(archetype, toneId, relationship, intensity);

    // 9. Build consent model
    const consent = this.buildConsentModel(archetype, toneId, trust);

    return {
      toneId,
      toneProfile,
      archetype: archetype.label,
      consent,
      emotions,
      dialogueStyle: archetype.dialogueStyle,
      touchStyle: archetype.touchStyle,
      aftercareNeeded: archetype.aftercareNeeded && toneProfile.roughness > 0.5,
      
      // Metadata for other systems
      animationParams: {
        speed: toneProfile.speed,
        roughness: toneProfile.roughness,
        eyeContact: toneProfile.eyeContact,
        kissFrequency: toneProfile.kissFrequency,
        touchGentleness: toneProfile.touchGentleness,
      },
      audioParams: {
        dialogueIntensity: toneProfile.dialogueIntensity,
        verbalAffection: toneProfile.verbalAffection,
        degradation: toneProfile.degradation,
        pain: toneProfile.painFocus,
      },
    };
  }

  /**
   * Select emotional reactions based on context
   */
  generateEmotionalContext(archetype, toneId, relationship, intensity) {
    // Available emotions from archetype
    const available = archetype.emotionalRange || [];
    
    // Select 2-3 emotions that match the current tone
    const toneEmotionMap = {
      tender: ['love', 'tenderness', 'vulnerability'],
      passionate: ['love', 'ecstasy', 'vulnerability'],
      playful: ['submission', 'dominance'],
      desperate: ['desperation', 'guilt', 'ecstasy'],
      rough: ['dominance', 'submission', 'ecstasy'],
      reverent: ['love', 'tenderness', 'vulnerability'],
      commanding: ['dominance', 'submission'],
      guilty: ['guilt', 'vulnerability', 'desperation'],
      aggressive: ['dominance', 'desperation'],
      sarcastic: ['dominance', 'submission'],
    };

    const toneEmotions = toneEmotionMap[toneId] || ['ecstasy'];
    
    // Filter to only available emotions for this archetype
    const matched = toneEmotions.filter(e => available.includes(e));
    
    // Pick 2
    const selected = matched.length >= 2 
      ? matched.slice(0, 2)
      : [...matched, 'ecstasy'];

    // Build reaction objects
    return selected.map(emotionId => {
      const reaction = this.EMOTIONAL_REACTIONS[emotionId];
      if (!reaction) return null;
      
      // Pick a dialogue line based on intensity
      const dialogueIndex = Math.min(
        Math.floor(intensity / 3) % reaction.dialogue.length,
        reaction.dialogue.length - 1
      );

      return {
        emotion: emotionId,
        dialogue: reaction.dialogue[dialogueIndex],
        physicalCues: reaction.physicalCues,
        breathing: reaction.breathingPattern,
      };
    }).filter(Boolean);
  }

