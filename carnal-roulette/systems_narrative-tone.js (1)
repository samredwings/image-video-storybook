        dominant: [`Take it. Take all of it ${partnerName}.`, `You were made for this.`],
        submissive: [`Please let me earn it.`, `Use me however you need.`],
      };
      
      const lines = degradationLines[toneResult.touchStyle] || degradationLines.dominant;
      return lines[Math.floor(Math.random() * lines.length)];
    }

    // Standard emotional dialogue
    return primaryEmotion.dialogue;
  }

