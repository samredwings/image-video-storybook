# ═══════════════════════════════════════════════════════════════════════════════
# STORYBOOK STUDIO — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# 🆓  FREE TIER (Default — NO payment required):
#     Most features work with just a FREE HuggingFace account:
#     1. Sign up at https://huggingface.co/join  (no credit card)
#     2. Generate token at https://huggingface.co/settings/tokens
#     3. Set HUGGINGFACE_API_KEY below
#
# 🔑  BYOK (Bring Your Own Key — Optional paid upgrades):
#     These are 100% OPTIONAL. Only set them if you have your own
#     paid subscriptions and want premium model access.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://storybook:storybook123@localhost:5432/image_video_storybook

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 / MinIO ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1
AWS_S3_BUCKET=video-storage
S3_ENDPOINT=http://localhost:9000

# ─── FREE TIER AI (Default — no payment required) ─────────────────────────────
# Get a free HuggingFace token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_free_huggingface_token

# Google Colab — Run inference on free GPU (alternative to HuggingFace)
# Point to your Colab notebook URL (via ngrok/Gradio share link)
# See colab/ directory for setup instructions
# COLAB_ENDPOINT=https://your-colab-notebook.ngrok.io

# ─── BYOK — OPTIONAL paid providers (only if you have your own keys) ──────────
# OpenAI GPT-4 — Premium story/roleplay quality
# OPENAI_API_KEY=sk-your-openai-api-key
#
# Runway ML — Advanced video generation
# RUNWAY_API_KEY=your_runway_api_key
#
# Pika Labs — Creative video generation
# PIKA_API_KEY=your_pika_api_key
#
# ElevenLabs — Professional voice narration
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
#
# Replicate — Style transfer and image processing
# REPLICATE_API_KEY=your_replicate_api_key

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
API_PORT=3001
WEB_PORT=3000
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d
CORS_ORIGIN=http://localhost:3000

# ─── Content Settings — NO RESTRICTIONS ──────────────────────────────────────
NSFW_DETECTION_ENABLED=false
ADULT_CONTENT_ALLOWED=true
UNRESTRICTED_MODE=true
CONTENT_FILTERING=none

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json

# ─── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=s3
STORAGE_LOCAL_PATH=./uploads

# ─── Features ─────────────────────────────────────────────────────────────────
FEATURE_BATCH_PROCESSING=true
FEATURE_WEBHOOKS=true
FEATURE_AUDIT_LOG=true
